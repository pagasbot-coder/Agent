# LLM providers (server-side only — never NEXT_PUBLIC_*)
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# Optional: default model routing (BFF /api/advisor/*)
ADVISOR_LLM_PROVIDER=deepseek
ADVISOR_LLM_MODEL=deepseek-chat
ADVISOR_MAX_TOKENS=512

# Cost guardrails (ADR-001 / Phase 4 — in-memory per instance)
ADVISOR_RATE_LIMIT_MAX=20
ADVISOR_RATE_LIMIT_WINDOW_MS=900000

# Redis / Upstash rate limit (T-036 — OFF until Human scopes keys)
REDIS_URL=
REDIS_TOKEN=
# Token budgets: 0 = disabled; weekly default protects staging spend
ADVISOR_DAILY_TOKEN_BUDGET=0
ADVISOR_WEEKLY_TOKEN_BUDGET=200000

# Analytics — PostHog OSS self-host (ADR-002; Phase 4; disabled by default)
POSTHOG_DISABLED=true
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://posthog.example.eu

# Optional: server-side BFF telemetry (Phase 4; no PII in properties)
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://posthog.example.eu

# Auth.js Phase 5 (ADR-003) — disabled by default; staging unchanged
AUTH_ENABLED=false
AUTH_SECRET=
AUTH_URL=https://quiet-partner.vercel.app

# Email magic link (Resend — when AUTH_ENABLED=true)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=noreply@example.com

# Optional OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# PostgreSQL (Neon/Supabase — no connection until Human scope)
DATABASE_URL=
